{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "la28",
  "compatibility_date": "2026-04-09",
  "compatibility_flags": ["nodejs_compat"],
  "main": "@tanstack/react-start/server-entry",
  "routes": [{ "pattern": "la28.tompark.dev", "custom_domain": true }],
  "observability": {
    "enabled": true,
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "la28",
      "database_id": "92ecfb14-5274-42b9-9493-166460e603c7",
      "migrations_dir": "drizzle",
    },
  ],
}
